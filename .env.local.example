# Supabase — get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — get this from resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# The email address that receives new contact form notifications
ADMIN_EMAIL=your@email.com

# Password to log into the admin dashboard at /admin
ADMIN_PASSWORD=choose-a-strong-password-here
